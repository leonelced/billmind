{
  "name": "billmind",
  "version": "1.0.0",
  "type": "module",
  "description": "Event-driven bill reminder service built with TypeScript and RabbitMQ.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeonelCedillo/billmind.git"
  },
  "scripts": {
    "rabbit:start": "./src/scripts/rabbit.sh start",
    "rabbit:stop": "./src/scripts/rabbit.sh stop",
    "rabbit:logs": "./src/scripts/rabbit.sh logs",
    
    "pg:start": "./src/scripts/postgres.sh start",
    "pg:stop": "./src/scripts/postgres.sh stop",
    "pg:logs": "./src/scripts/postgres.sh logs",

    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",

    "scheduler": "npx tsx src/scheduler/index.ts",
    "notifier": "npx tsx src/notifier/index.ts"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  }
}
